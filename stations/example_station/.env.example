# AI Radio FM — Per-Station Environment Variables
# Copy to stations/<station_name>/.env and fill in values.
# Values here override stations/.env.shared for this station only.

# API server listen address for this station (must be unique across all stations).
API_ADDR=:8001

# Icecast mount point for this station (must be unique across all stations).
# Defaults to /<station_name> if not set.
# ICECAST_MOUNT=example_station

# Inventory threshold — number of audio files to keep buffered per show.
# The daemon generates more content when inventory drops below this number.
# Default: 5
# INVENTORY_THRESHOLD=5

# Anthropic base URL — override to use alternative providers or local proxies.
# Default: https://api.anthropic.com
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Override Icecast connection for this station (usually set in .env.shared).
# ICECAST_HOST=localhost
# ICECAST_PORT=8000
# ICECAST_USER=source
# ICECAST_PASSWORD=hackme

# TTS gRPC sidecar address (usually set in .env.shared).
# TTS_GRPC_ADDR=localhost:50051

# MusicGen server URL (usually set in .env.shared).
# MUSICGEN_URL=http://localhost:8002

# Anthropic API key (usually set in .env.shared).
# ANTHROPIC_API_KEY=sk-ant-...

# Content, archive, and ledger paths default to stations/<name>/content/,
# stations/<name>/archive/, and stations/<name>/ledger.jsonl respectively.
# Override here only if you need non-standard paths.
# CONTENT_DIR=stations/example_station/content
# ARCHIVE_DIR=stations/example_station/archive
# LEDGER_PATH=stations/example_station/ledger.jsonl
