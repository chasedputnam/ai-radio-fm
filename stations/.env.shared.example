# AI Radio FM — Shared Environment Variables
# Copy to stations/.env.shared and fill in values.
# These apply to ALL stations. Per-station .env files override individual values.

# Anthropic API key for script generation.
ANTHROPIC_API_KEY=sk-ant-...

# Anthropic API base URL. Override to use alternative providers or local proxies
# that implement the Anthropic Messages API (e.g. LiteLLM, OpenRouter).
# Default: https://api.anthropic.com
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Icecast server connection (shared instance, all stations use different mounts).
ICECAST_HOST=localhost
ICECAST_PORT=8000
ICECAST_USER=source
ICECAST_PASSWORD=hackme

# TTS gRPC sidecar address (single shared instance for all stations).
TTS_GRPC_ADDR=localhost:50051

# MusicGen server URL (single shared instance for all stations).
MUSICGEN_URL=http://localhost:8002

# Kokoro TTS sidecar binary paths (used when starting tts-server).
KOKORO_LIB_PATH=/opt/homebrew/lib/libonnxruntime.dylib
KOKORO_MODEL_PATH=./go-kokoro-tts/kokoro-v0_19.onnx
KOKORO_VOICE_DIR=./go-kokoro-tts/voices
KOKORO_COREML=true
