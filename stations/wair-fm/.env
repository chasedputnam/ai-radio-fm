# WAIR-FM per-station environment
# API port — must be unique across all stations
API_ADDR=:8001

# Icecast mount defaults to /wair-fm — override here if needed
# ICECAST_MOUNT=wair-fm

# Inventory threshold — number of audio files to keep buffered per show.
# The daemon generates more content when inventory drops below this number.
# Default: 5
# INVENTORY_THRESHOLD=5
